# Browser-safe Supabase connection values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Storage remains disabled until supabase/storage/README.md is approved and completed.
NEXT_PUBLIC_SUPABASE_STORAGE_ENABLED=false

# Local CLI only. Never prefix this value with NEXT_PUBLIC_ and never commit a real password.
SUPABASE_DATABASE_PASSWORD=replace-in-local-env-only
