    "@radix-ui/react-tabs": "1.1.13",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "@uppy/core": "5.2.0",
    "clsx": "2.1.1",
    "lucide-react": "0.468.0",
    "next": "16.2.11",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-hook-form": "7.71.1",
    "tailwind-merge": "3.4.1",
    "yet-another-react-lightbox": "3.29.1",
