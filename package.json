  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --max-http-header-size=65536 node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "node --max-http-header-size=65536 node_modules/next/dist/bin/next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "supabase": "supabase",
    "supabase:test:db": "supabase test db",
    "supabase:db:lint": "supabase db lint --linked",
